    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('user_email', 'sentinel+' + Date.now() + '@example.com');",
                  "if (!pm.collectionVariables.get('user_password')) pm.collectionVariables.set('user_password', 'ClaveSegura123');",
                  "['access_token','refresh_token','auth_user_id','profile_id','contact_id','incident_id','evidence_id'].forEach(function (key) { pm.collectionVariables.unset(key); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data || {};",
                  "if (data.user && data.user.id) pm.collectionVariables.set('auth_user_id', data.user.id);",
                  "if (data.session && data.session.access_token) pm.collectionVariables.set('access_token', data.session.access_token);",
                  "if (data.session && data.session.refresh_token) pm.collectionVariables.set('refresh_token', data.session.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/auth/register"
          },
          "response": []
        },
